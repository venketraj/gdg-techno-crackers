# Database provider options: postgres | demo
DATABASE_PROVIDER=demo
DATABASE_URL=

# Storage provider options: memory | local
STORAGE_PROVIDER=memory

# AI provider options: mock | openai-compatible
AI_PROVIDER=mock
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=https://openrouter.ai/api/v1
OPENAI_COMPATIBLE_MODEL=google/gemini-3.1-flash-lite-image
OPENAI_COMPATIBLE_SITE_URL=http://localhost:3000
OPENAI_COMPATIBLE_APP_NAME=Constituency Intelligence MVP

# Demo controls
CLUSTER_RADIUS_METERS=150
SENSITIVE_PLACE_RADIUS_METERS=300
OPEN_METEO_ENABLED=true
NEXT_PUBLIC_DEFAULT_LATITUDE=9.9252
NEXT_PUBLIC_DEFAULT_LONGITUDE=78.1198
NEXT_PUBLIC_DEFAULT_ZOOM=13
